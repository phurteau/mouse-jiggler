# Ignore Python bytecode files
__pycache__/
*.pyc
*.pyo

# Ignore VS Code settings and workspace files
.vscode/

# Ignore OS-specific files (macOS, Windows)
.DS_Store
Thumbs.db

# Ignore build artifacts from PyInstaller (if you create an executable)
dist/
build/

# Ignore the app's runtime config (written next to the app when it runs)
zen-jiggler-config.json

# Ignore any virtual environment directories (if using one)
venv/
